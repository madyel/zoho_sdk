# Zoho Vertical SDK – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OAuth credentials ────────────────────────────────────────────────────────

# Client credentials (from Zoho Developer Console → Self Client)
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Refresh token (long-lived; generated during first OAuth flow)
ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Static access token (short-lived; alternative to refresh flow)
# ZOHO_ACCESS_TOKEN=100xx.xxxxxxxxxx.xxxxxxxxxx

# ── Data centre ───────────────────────────────────────────────────────────────
# One of: US (default) | EU | IN | AU | JP
ZOHO_DATA_CENTRE=US

# ── API endpoints (derived automatically from ZOHO_DATA_CENTRE if omitted) ───
# ZOHO_API_DOMAIN=https://zohoverticalapis.com
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# ── Integration tests (examples_test.py) ─────────────────────────────────────
# ZOHO_TEST_MODULE=Employee
# ZOHO_TEST_RECORD_ID=
